# ================================================================
# Nexora Backend - Environment Variables Template
# ================================================================
# SECURITY: This file is a TEMPLATE with NO secrets
# Copy to .env and fill with actual values
# NEVER commit .env to git - always use secret managers in production
# ================================================================

# ─── NODE ENVIRONMENT ────────────────────────────────────────────
# Values: development | test | production
# ⚠️  Must be 'production' in production environments
NODE_ENV=development

# ─── APPLICATION SERVER ─────────────────────────────────────────
PORT=3004
BACKEND_URL=http://localhost:3004
FRONTEND_URL=http://localhost:4200
CORS_ORIGINS=http://localhost:4200,http://localhost:3004
CORS_ORIGIN=http://localhost:4200
ASSET_UPLOAD_DIR=uploads/assets

# Public user registration (disabled by default, enable only for demos)
AUTH_ENABLE_PUBLIC_REGISTER=false

# ─── DATABASE CONFIGURATION ─────────────────────────────────────
# ⚠️  CRITICAL: PostgreSQL REQUIRED in production
# For production, use: DB_TYPE=postgres with secure connection
DB_TYPE=postgres

# Option 1: Connection URL (recommended for cloud deployments)
# Format: postgresql://user:password@host:port/database?ssl=require
DATABASE_URL=postgresql://app_user:replace-me@postgres.example.com:5432/nexora

# Option 2: Individual parameters (recommended for local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=metaiq
DB_USER=metaiq
DB_PASSWORD=your-secure-password
DB_SSL=false
# In production, use: DB_SSL=true (with rejectUnauthorized: false only if using self-signed certs)

# TypeORM Migrations & Logging
TYPEORM_SYNCHRONIZE=false
TYPEORM_MIGRATIONS_RUN=false
TYPEORM_LOGGING=false

# ─── AUTHENTICATION & JWT ───────────────────────────────────────
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ⚠️  Change EVERY secret in production - these are examples only
JWT_SECRET=replace-me-with-secure-jwt-secret-minimum-48-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-me-with-secure-refresh-secret-minimum-48-chars
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=replace-me-with-secure-cookie-secret-minimum-32-chars

# ─── ENCRYPTION (AES-256) ───────────────────────────────────────
# Used for Meta access token encryption at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️  Must be exactly 32 bytes (64 hex characters)
CRYPTO_SECRET=replace-me-with-secure-crypto-secret-exactly-32-bytes

# Meta OAuth per Store
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3004/api/integrations/meta/oauth/callback
META_API_VERSION=v19.0
META_OAUTH_SCOPES=ads_read,business_management
# Keep false outside local test fixtures. Real flow never accepts manual tokens.
AUTH_ENABLE_DEV_META_CONNECT=false

# Gemini
GEMINI_API_KEY=replace-me-with-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_VERSION=v1beta
