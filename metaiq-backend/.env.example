# MetaIQ Backend example environment variables
# Copy this file to .env and replace every secret before using production.

# App
NODE_ENV=development
PORT=3004
FRONTEND_URL=http://localhost:4200
# Keep public registration disabled unless explicitly needed for local demos.
AUTH_ENABLE_PUBLIC_REGISTER=false

# Platform master user created/updated by npm run seed.
# Use real values only in your local .env or secret manager.
PLATFORM_ADMIN_EMAIL=admin.platform@example.com
PLATFORM_ADMIN_PASSWORD=replace-with-a-strong-master-password
PLATFORM_ADMIN_NAME=Administrador da Plataforma

# Database
# PostgreSQL is the primary local development path.
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=metaiq
DB_USER=metaiq
DB_PASSWORD=metaiq
DB_SSL=false
# Optional URL form:
# DB_URL=postgres://metaiq:metaiq@localhost:5432/metaiq

# Legacy SQLite fallback for isolated tests or emergency local debugging.
# DB_TYPE=sqlite
# SQLITE_PATH=./data/metaiq.db

# TypeORM
# Use migrations for Postgres. Keep synchronize false.
TYPEORM_SYNCHRONIZE=false
TYPEORM_MIGRATIONS_RUN=false
TYPEORM_LOGGING=false

# JWT
JWT_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-refresh-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Crypto
# Used to encrypt Meta access tokens at rest. Use a unique high-entropy value.
CRYPTO_SECRET=replace-with-a-long-random-crypto-secret

# Meta OAuth per Store
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3004/api/integrations/meta/oauth/callback
META_API_VERSION=v19.0
META_OAUTH_SCOPES=ads_read,business_management
# Keep false outside local test fixtures. Real flow never accepts manual tokens.
AUTH_ENABLE_DEV_META_CONNECT=false

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_VERSION=v1beta
