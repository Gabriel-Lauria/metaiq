# MetaIQ Backend example environment variables
# Copy this file to .env and replace every secret before using production.

# App
NODE_ENV=development
PORT=3004
FRONTEND_URL=http://localhost:4200

# Database
# Local development defaults to SQLite.
DATABASE_TYPE=sqlite
SQLITE_PATH=./data/metaiq.db

# PostgreSQL production example:
# DATABASE_TYPE=postgres
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/metaiq
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=metaiq
# POSTGRES_SSL=false

# TypeORM
# Development can use synchronize for convenience. Keep it false in production.
TYPEORM_SYNCHRONIZE=true
TYPEORM_MIGRATIONS_RUN=false
TYPEORM_LOGGING=false

# JWT
JWT_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-refresh-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Crypto
# Used to encrypt Meta access tokens at rest. Use a unique high-entropy value.
CRYPTO_SECRET=replace-with-a-long-random-crypto-secret

# Meta / Facebook placeholder integration
META_GRAPH_API_URL=https://graph.facebook.com/v17.0
META_ACCESS_TOKEN=
